# ===========================================================================
# Backend (LangGraph server) environment.
#
# This project runs in ONE of two modes, decided automatically by which vars
# are set (see src/shared/retrieval.ts -> isCloudMode()):
#
#   LOCAL  (default) : Ollama LLM + embeddings, in-memory vector store.
#                      Free, offline, no accounts. Leave the CLOUD block blank.
#
#   CLOUD  (deploy)  : Google Gemini LLM + embeddings, Supabase vector store.
#                      Enabled when GOOGLE_API_KEY, SUPABASE_URL and
#                      SUPABASE_SERVICE_ROLE_KEY are ALL set.
# ===========================================================================

# ---------------------------------------------------------------------------
# CLOUD mode (fill these to deploy; leave blank for local Ollama)
# ---------------------------------------------------------------------------

# Google Gemini API key — get a free one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Supabase project (free tier). Dashboard -> Project Settings -> Data API / API keys.
# Use the SERVICE ROLE key (server-side only — never expose it to the browser).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Chat model as "provider/model". For Gemini cloud mode use a google-genai model.
# Default (local) is ollama/llama3.2. Uncomment for cloud:
# QUERY_MODEL=google-genai/gemini-2.0-flash

# Embedding model (Gemini). Its dimension MUST match supabase_setup.sql (768).
# EMBEDDING_MODEL=text-embedding-004

# ---------------------------------------------------------------------------
# LOCAL mode overrides (optional; defaults shown)
# ---------------------------------------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ---------------------------------------------------------------------------
# Not used in this build, kept blank for template compatibility
# ---------------------------------------------------------------------------
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Optional: LangSmith tracing (leave blank to disable)
# ---------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=ai-agent-pdf-chatbot
