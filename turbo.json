{
    "$schema": "https://turbo.build/schema.json",
    "globalDependencies": ["**/.env"],
    "tasks": {
      "build": {
        "dependsOn": ["^build"],
        "outputs": ["**/dist/**", ".next/**"]
      },
      "lint": {
        "dependsOn": ["^lint"]
      },
      "format": {
        "dependsOn": ["^format"]
      }
    }
  }