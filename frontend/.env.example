# ===========================================================================
# Frontend (Next.js) environment.
#
# The Next.js API routes proxy to the LangGraph backend server. Point them at
# your running backend via NEXT_PUBLIC_LANGGRAPH_API_URL.
# ===========================================================================

# URL of the LangGraph backend.
#   Local dev   : http://localhost:2024
#   Deployed    : your Render backend URL, e.g. https://your-app.onrender.com
NEXT_PUBLIC_LANGGRAPH_API_URL=http://localhost:2024

# Only needed to reach a LangGraph *Cloud* deployment. The self-hosted
# `langgraph dev` server (what we deploy to Render) needs no key — leave blank.
LANGCHAIN_API_KEY=

# Graph/assistant IDs (defined in backend/langgraph.json) — do not change.
LANGGRAPH_INGESTION_ASSISTANT_ID=ingestion_graph
LANGGRAPH_RETRIEVAL_ASSISTANT_ID=retrieval_graph

# Chat model as "provider/model", forwarded to the backend per request.
# Local default is ollama/llama3.2. For the Gemini cloud deploy, set:
#   NEXT_PUBLIC_QUERY_MODEL=google-genai/gemini-2.0-flash
NEXT_PUBLIC_QUERY_MODEL=ollama/llama3.2

# Optional: LangSmith tracing (leave blank to disable)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=pdf-chatbot
